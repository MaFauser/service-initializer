{
  "yaml.validate": false,
  "files.insertFinalNewline": true,
  "files.trimTrailingWhitespace": true,
  "files.encoding": "utf8",
  "[kotlin]": {
    "editor.defaultFormatter": "fwcd.kotlin",
    "editor.formatOnSave": false,
    "editor.tabSize": 4,
    "editor.insertSpaces": true,
    "editor.detectIndentation": false,
    "editor.rulers": [
      120
    ]
  },
  "[kotlin-script]": {
    "editor.defaultFormatter": "fwcd.kotlin",
    "editor.formatOnSave": false,
    "editor.tabSize": 4,
    "editor.insertSpaces": true,
    "editor.detectIndentation": false,
    "editor.rulers": [
      120
    ]
  },
  "files.exclude": {
    "**/build": true,
    "**/.gradle": true,
    "**/node_modules": true,
    "**/bin": true,
    "**/.idea": true,
  },
  "search.exclude": {
    "**/build": true,
    "**/.gradle": true,
    "**/node_modules": true,
    "**/bin": true,
    "**/.idea": true,
  }
}
